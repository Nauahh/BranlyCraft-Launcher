<div id="landingContainer" style="display: none;">

    <!-- ═══ SIDEBAR ICÔNES (style Paladium) ═══ -->
    <aside class="bc-sidebar">

        <!-- Avatar utilisateur -->
        <div class="bc-avatar-wrap">
            <div id="avatarContainer">
                <button id="avatarOverlay">✎</button>
            </div>
            <div class="bc-avatar-dot"></div>
        </div>

        <div class="bc-sidebar-divider"></div>

        <!-- Icône serveur actif -->
        <div id="image_seal_container" class="bc-icon-btn bc-icon-active" title="BranlyCraft">
            <img id="image_seal" src="assets/images/SealCircle.png"/>
            <div id="updateAvailableTooltip" style="display:none;"></div>
        </div>

        <div class="bc-sidebar-spacer"></div>

        <!-- Settings -->
        <button class="bc-icon-btn" id="settingsMediaButton" title="Paramètres">
            <svg viewBox="0 0 141.36 137.43" class="bc-icon-svg"><path d="M70.70475616319865,83.36934004916053 a15.320781354859122,15.320781354859122 0 1 1 14.454501310561755,-15.296030496450625 A14.850515045097694,14.850515045097694 0 0 1 70.70475616319865,83.36934004916053 M123.25082856443602,55.425620905968366 h-12.375429204248078 A45.54157947163293,45.54157947163293 0 0 0 107.21227231573047,46.243052436416285 l8.613298726156664,-9.108315894326587 a9.727087354538993,9.727087354538993 0 0 0 0,-13.167456673319956 l-3.465120177189462,-3.6631270444574313 a8.489544434114185,8.489544434114185 0 0 0 -12.375429204248078,0 l-8.613298726156664,9.108315894326587 A40.442902639482725,40.442902639482725 0 0 0 81.99114759747292,25.427580514871032 V12.532383284044531 a9.108315894326587,9.108315894326587 0 0 0 -8.811305593424633,-9.306322761594556 h-4.950171681699231 a9.108315894326587,9.108315894326587 0 0 0 -8.811305593424633,9.306322761594556 v12.895197230826497 a40.17064319698927,40.17064319698927 0 0 0 -9.331073620003052,4.0591407789933704 l-8.613298726156664,-9.108315894326587 a8.489544434114185,8.489544434114185 0 0 0 -12.375429204248078,0 L25.58394128451018,23.967279868769744 a9.727087354538993,9.727087354538993 0 0 0 0,13.167456673319956 L34.19724001066683,46.243052436416285 a45.07131316187151,45.07131316187151 0 0 0 -3.6631270444574313,9.083565035918088 h-12.375429204248078 a9.083565035918088,9.083565035918088 0 0 0 -8.811305593424633,9.306322761594556 v5.197680265784193 a9.108315894326587,9.108315894326587 0 0 0 8.811305593424633,9.306322761594556 h11.979415469712139 a45.69008462208391,45.69008462208391 0 0 0 4.0591407789933704,10.642869115653347 l-8.613298726156664,9.108315894326587 a9.727087354538993,9.727087354538993 0 0 0 0,13.167456673319956 l3.465120177189462,3.6631270444574313 a8.489544434114185,8.489544434114185 0 0 0 12.375429204248078,0 l8.613298726156664,-9.108315894326587 a40.49240435629971,40.49240435629971 0 0 0 9.331073620003052,4.0591407789933704 v12.895197230826497 a9.083565035918088,9.083565035918088 0 0 0 8.811305593424633,9.306322761594556 h4.950171681699231 A9.083565035918088,9.083565035918088 0 0 0 81.99114759747292,123.68848839660077 V110.79329116577425 a40.78941465720167,40.78941465720167 0 0 0 9.331073620003052,-4.0591407789933704 l8.613298726156664,9.108315894326587 a8.489544434114185,8.489544434114185 0 0 0 12.375429204248078,0 l3.465120177189462,-3.6631270444574313 a9.727087354538993,9.727087354538993 0 0 0 0,-13.167456673319956 l-8.613298726156664,-9.108315894326587 a45.665333763675406,45.665333763675406 0 0 0 4.034389920584874,-10.642869115653347 h12.004166328120636 a9.108315894326587,9.108315894326587 0 0 0 8.811305593424633,-9.306322761594556 v-5.197680265784193 a9.083565035918088,9.083565035918088 0 0 0 -8.811305593424633,-9.306322761594556 "/></svg>
        </button>

        <!-- Statut Mojang -->
        <div id="mojangStatusWrapper" class="bc-icon-btn" title="Statut Mojang">
            <span id="mojang_status_icon">&#8226;</span>
            <div id="mojangStatusTooltip">
                <div id="mojangStatusTooltipTitle"><%- lang('landing.mojangStatusTooltipTitle') %></div>
                <div id="mojangStatusEssentialContainer"></div>
                <div id="mojangStatusNEContainer">
                    <div class="mojangStatusNEBar"></div>
                    <div id="mojangStatusNETitle"><%- lang('landing.mojangStatusNETitle') %></div>
                    <div class="mojangStatusNEBar"></div>
                </div>
                <div id="mojangStatusNonEssentialContainer"></div>
            </div>
        </div>

    </aside>

    <!-- ═══ ZONE PRINCIPALE ═══ -->
    <main class="bc-main">

        <!-- Badge + Titre + Actions (overlay bas gauche) -->
        <div class="bc-hero-overlay">

            <h1 class="bc-big-title">TEST</h1>

            <p class="bc-subtitle">
                Le serveur Minecraft des lycéens, avec 500 mods soigneusement sélectionnés.<br>
                Explore des dimensions inédites, affronte des boss épiques, construis et forge ton empire.<br>
                <span class="bc-subtitle-meta">Saison 2 · 500 mods · Minecraft 1.21.1</span>
            </p>

            <!-- Joueurs en ligne -->
            <div id="server_status_wrapper" class="bc-online">
                <span class="bc-online-dot"></span>
                <span id="player_count">—</span>
                <span class="bc-online-label" id="landingPlayerLabel">joueurs en ligne</span>
                <span id="server_status_badge" class="bc-status-badge bc-status-unknown"></span>
            </div>

            <!-- Avatars des joueurs Minecraft en ligne -->
            <div id="bc-online-avatars" class="bc-player-avatars" style="display:none;"></div>

            <!-- Boutons PLAY + settings -->
            <div class="bc-actions">
                <div id="launch_content">
                    <button id="launch_button">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="white"><path d="M8 5v14l11-7z"/></svg>
                        <%- lang('landing.launchButton') %>
                    </button>
                    <button id="settingsMediaButton2" class="bc-gear-btn" style="display:none;"></button>
                    <button id="screenshotsBtn" class="bc-screenshots-btn" title="Ouvrir le dossier screenshots">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M9 2L7.17 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2h-3.17L15 2H9zm3 15c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5z"/></svg>
                        Screenshots
                    </button>
                </div>
                <div id="launch_details" style="display: none;">
                    <div id="launch_details_left">
                        <span id="launch_progress_label">0%</span>
                    </div>
                    <div id="launch_details_right">
                        <progress id="launch_progress" value="22" max="100"></progress>
                        <span id="launch_details_text" class="bc-online-label"><%- lang('landing.launchDetails') %></span>
                    </div>
                </div>
            </div>

            <!-- Sélecteur serveur (masqué - launcher mono-serveur) -->
            <button id="server_selection_button" class="bc-server-select" style="display:none;">
                <%- lang('landing.launchButtonPlaceholder') %>
            </button>

        </div>

        <!-- Nom utilisateur coin haut droit -->
        <div class="bc-user-corner">
            <div class="bc-user-card">
                <div id="userHeadMini"></div>
                <div class="bc-user-info">
                    <span class="bc-user-name" id="user_text">—</span>
                    <span class="bc-user-status"><span class="bc-user-dot"></span>En ligne</span>
                    <span class="bc-user-playtime" id="user_playtime"></span>
                </div>
            </div>
        </div>

        <!-- Panneau membres Discord (côté droit) -->
        <div id="bc-discord-panel" class="bc-discord-panel" style="display:none;">
            <div class="bc-discord-panel-header">
                <svg viewBox="0 0 24 24" width="12" height="12" fill="#5865F2"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
                <span class="bc-discord-panel-title">DISCORD</span>
                <span id="bc-discord-count" class="bc-discord-count-badge">0</span>
            </div>
            <div id="bc-discord-members" class="bc-discord-members-list"></div>
        </div>

        <!-- Section news en bas -->
        <div class="bc-bottom">
            <div class="bc-section-title">
                <span>DERNIÈRES NEWS</span>
                <button id="newsButton" class="bc-news-btn">
                    <div id="newsButtonAlert" style="display: none;"></div>
                    <svg id="newsButtonSVG" viewBox="0 0 24.87 13.97" width="12"><polyline style="fill:none;stroke:currentColor;stroke-width:2px;" points="0.71 13.26 12.56 1.41 24.16 13.02"/></svg>
                    <span id="newsButtonText"><%- lang('landing.newsButton') %></span>
                </button>
            </div>

            <div id="newsContainer">
                <div id="newsContent" article="-1" style="display: none;">
                    <div id="newsStatusContainer">
                        <div id="newsStatusContent">
                            <div id="newsTitleContainer"><a id="newsArticleTitle" href="#">—</a></div>
                            <div id="newsMetaContainer">
                                <div id="newsArticleDateWrapper"><span id="newsArticleDate"></span></div>
                                <div id="newsArticleAuthorWrapper"><span id="newsArticleAuthor"></span></div>
                                <a href="#" id="newsArticleComments">0 Comments</a>
                            </div>
                        </div>
                        <div id="newsNavigationContainer">
                            <button id="newsNavigateLeft"><svg id="newsNavigationLeftSVG" viewBox="0 0 24.87 13.97"><polyline style="fill:none;stroke:#FFF;stroke-width:2px;" points="0.71 13.26 12.56 1.41 24.16 13.02"/></svg></button>
                            <span id="newsNavigationStatus"><%- lang('landing.newsNavigationStatus', { currentPage: 1, totalPages: 1 }) %></span>
                            <button id="newsNavigateRight"><svg id="newsNavigationRightSVG" viewBox="0 0 24.87 13.97"><polyline style="fill:none;stroke:#FFF;stroke-width:2px;" points="0.71 13.26 12.56 1.41 24.16 13.02"/></svg></button>
                        </div>
                    </div>
                    <div id="newsArticleContainer">
                        <div id="newsArticleContent"><div id="newsArticleContentScrollable"></div></div>
                    </div>
                </div>
                <div id="newsErrorContainer">
                    <div id="newsErrorLoading"><span id="nELoadSpan" class="newsErrorContent"><%- lang('landing.newsErrorLoadSpan') %></span></div>
                    <div id="newsErrorFailed" style="display:none;"><span id="nEFailedSpan" class="newsErrorContent"><%- lang('landing.newsErrorFailedSpan') %></span><button id="newsErrorRetry"><%- lang('landing.newsErrorRetryButton') %></button></div>
                    <div id="newsErrorNone" style="display:none;"><span id="nENoneSpan" class="newsErrorContent"><%- lang('landing.newsErrorNoneSpan') %></span></div>
                </div>
            </div>
        </div>

    </main>

    <script src="./assets/js/scripts/landing.js"></script>
    <script>
    (function() {
        const pc = document.getElementById('player_count');
        const sw = document.getElementById('server_status_wrapper');
        if (!pc || !sw) return;
        function updateDot() {
            const offline = pc.textContent.trim() === 'OFFLINE';
            sw.classList.toggle('server-offline', offline);
        }
        new MutationObserver(updateDot).observe(pc, { childList: true, subtree: true, characterData: true });
    })();
    </script>
</div>
